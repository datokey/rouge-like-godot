upgrade_options = Array[Resource]([SubResource("Upgrade_summon_attack_speed"), SubResource("Upgrade_projectile_count"), SubResource("Upgrade_attack_range"), SubResource("Upgrade_pierce"), SubResource("Upgrade_summon_damage")])
