[ext_resource type="Script" uid="uid://6lbrueteqscn" path="res://upgrades/scripts/WeaponUpgradeDefinition.gd" id="3_upgrade"]

[sub_resource type="Resource" id="Upgrade_damage"]
script = ExtResource("3_upgrade")
id = "damage"
display_name = "Damage"
modifier_key = &"weapon.damage"
stat_type = 6

[sub_resource type="Resource" id="Upgrade_radius"]
script = ExtResource("3_upgrade")
id = "radius"
display_name = "Aura Radius"
modifier_key = &"weapon.aura_radius"
stat_type = 7

[sub_resource type="Resource" id="Upgrade_tick_rate"]
script = ExtResource("3_upgrade")
id = "tick_rate"
display_name = "Tick Rate"
modifier_key = &"weapon.aura_tick_interval"
stat_type = 0

[resource]
script = ExtResource("1_aura_def")
slow_percent = 0.4
id = "weapon_aura"
display_name = "Frost Aura"
description = "Aura yang selalu mengikuti player. Musuh di dalam area akan menerima damage dan efek slow."
weapon_type = 1
weapon_scene = ExtResource("2_aura_scene")
compatibility_tags = Array[StringName]([&"AURA", &"CAN_CRIT", &"CAN_LIFESTEAL"])
upgrade_options = Array[Resource]([SubResource("Upgrade_damage"), SubResource("Upgrade_radius"), SubResource("Upgrade_tick_rate")])
