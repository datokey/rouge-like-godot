[gd_resource type="Resource" script_class="AbilityDefinition" load_steps=4 format=3]

[ext_resource type="Script" path="res://abilities/scripts/AbilityDefinition.gd" id="1_definition"]
[ext_resource type="Script" path="res://abilities/scripts/AbilityEffect.gd" id="2_effect"]
[ext_resource type="Script" path="res://abilities/scripts/AbilityPrerequisiteRule.gd" id="3_rule"]

[sub_resource type="Resource" id="Prerequisite_template"]
script = ExtResource("3_rule")
minimum_player_level = 2
required_card_ids = Array[String]([])
blocked_card_ids = Array[String]([])
required_weapon_ids = Array[String]([])
required_skill_ids = Array[String]([])

[sub_resource type="Resource" id="Effect_buff"]
script = ExtResource("2_effect")
modifier_key = &"weapon.damage"
value = 0.25
value_type = 1

[sub_resource type="Resource" id="Effect_tradeoff"]
script = ExtResource("2_effect")
modifier_key = &"player.move_speed"
value = -0.05
value_type = 1

[resource]
script = ExtResource("1_definition")
id = "TEMPLATE_CARD"
display_name = "Template Card"
description = "Duplicate resource ini, ganti semua metadata, effect, dan prerequisite."
category = "Risky"
rarity = "Uncommon"
archetype = "Brutal"
enabled = false
stackable = true
max_stack = 5
weight = 1.0
eligibility_rules = Array[Resource]([SubResource("Prerequisite_template")])
effects = Array[Resource]([SubResource("Effect_buff"), SubResource("Effect_tradeoff")])
